{
    "comments": {
        "lineComment": "#",
        "blockComment": ["#[[", "#]]"]
    },
    // symbols used as brackets
    "brackets": [
        ["{", "}"],
        ["${", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    // symbols that are auto closed when typing
    "autoClosingPairs": [
        ["{", "}"],
        ["${", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"\"\"", "\"\"\""],
        ["'''", "'''"],
        ["\"", "\""],
        ["'", "'"]
    ],
    // symbols that can be used to surround a selection
    "surroundingPairs": [
        ["{", "}"],
        ["${", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"\"\"", "\"\"\""],
        ["\"", "\""],
        ["'''", "'''"],
        ["'", "'"]
    ],
    // Indent after certain keywords
    "indentationRules": {
        "increaseIndentPattern": "\\b(do|then|else)\\s*\\b|\\b(subroutine|function)[ \\t]+[^'\"\\$\\{\\} \\t]+",
        "decreaseIndentPattern": "(?<!\\$)\\s*\\b(end|else|elif)\\b\\s*"
    }
}
