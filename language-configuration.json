{
    "comments": {
        "lineComment": "#",
        "blockComment": ["#[[", "#]]"]
    },
    // symbols used as brackets
    "brackets": [
        ["{", "}"],
        ["${", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    // symbols that are auto closed when typing
    "autoClosingPairs": [
        ["{", "}"],
        ["${", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"\"\"", "\"\"\""],
        ["'''", "'''"],
        ["\"", "\""],
        ["'", "'"]
    ],
    // symbols that can be used to surround a selection
    "surroundingPairs": [
        ["{", "}"],
        ["${", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"\"\"", "\"\"\""],
        ["\"", "\""],
        ["'''", "'''"],
        ["'", "'"]
    ],
    // Indent after certain keywords
    "indentationRules": {
        "increaseIndentPattern": "^((?!(#)).)*((\\b(subroutine|function|else|then|do)\\b((?!\\b(end)\\b).)*)|(\\{\\s*))$",
		"decreaseIndentPattern": "^\\s*((\\b(elif|else|end)\\b)|(\\})|(\\)))"
    }
}
